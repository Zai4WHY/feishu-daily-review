# DeepSeek API Key（在 platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx

# KV 存储（Vercel 自动注入，无需手动填写）
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Web Push VAPID 密钥（生成方式: npx web-push generate-vapid-keys）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your-email@example.com

# Cron 密钥（可选，保护 cron 端点）
CRON_SECRET=random-secret-string

# 订阅者 ID（可选，用于区分多用户，默认 "default"）
SUBSCRIBER_ID=default
