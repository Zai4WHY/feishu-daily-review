{
  "regions": ["sin1"],
  "functions": {
    "api/messages.ts": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/proxy.ts": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/cron.ts": {
      "memory": 1024,
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 16 * * *"
    }
  ]
}
